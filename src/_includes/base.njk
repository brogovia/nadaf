<!DOCTYPE html>
<html lang="{{ lang | default('fr') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default('NADAF') }}</title>
    <meta name="description" content="{{ description | default('NADAF - Spécialiste du recyclage papier et carton en Algérie.') }}">
    <link rel="canonical" href="{{ metadata.baseUrl }}{{ page.url }}">
    <link rel="alternate" hreflang="fr" href="{{ metadata.baseUrl }}{{ page.url }}">
    <link rel="alternate" hreflang="x-default" href="{{ metadata.baseUrl }}/fr/">
    {% if robots %}<meta name="robots" content="{{ robots }}">{% endif %}
    <link rel="stylesheet" href="/static/css/main.css">
    <link rel="icon" href="/static/images/icons/logo_nadaf.png" type="image/x-icon">
    {# Add links to Google Fonts #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
    {# Add links to Google Fonts if needed later #}
    {# Example: <link href="https://fonts.googleapis.com/css2?family=Lato&family=Montserrat&display=swap" rel="stylesheet"> #}

    {# --- Open Graph Meta Tags --- #}
    <meta property="og:title" content="{{ title | default('NADAF - Recyclage Papier & Carton') }}">
    <meta property="og:description" content="{{ description | default('Collecte et valorisation de déchets papier et carton pour les entreprises en Algérie.') }}">
    {# Utilisation de la variable metadata.baseUrl #}
    <meta property="og:image" content="{{ metadata.baseUrl }}/static/images/logo_nadaf.jpg"> {# Utilisation du logo actuel #}
    <meta property="og:image:alt" content="Logo NADAF"> {# Alt text pour l'image OG #}
    {# Utilisation de la variable metadata.baseUrl #}
    <meta property="og:url" content="{{ metadata.baseUrl }}{{ page.url }}">
    <meta property="og:type" content="website">
    <meta property="og:locale" content="fr_FR">
    <meta property="og:site_name" content="NADAF">

    {# --- Twitter Card Meta Tags (Optionnel mais recommandé) --- #}
    <meta name="twitter:card" content="summary"> {# 'summary' est souvent mieux pour les logos carrés #}
    <meta name="twitter:title" content="{{ title | default('NADAF - Recyclage Papier & Carton') }}">
    <meta name="twitter:description" content="{{ description | default('Collecte et valorisation de déchets papier et carton pour les entreprises en Algérie.') }}">
    {# Utilisation de la variable metadata.baseUrl #}
    <meta name="twitter:image" content="{{ metadata.baseUrl }}/static/images/logo_nadaf.jpg"> {# Utilisation du logo actuel #}
    <meta name="twitter:image:alt" content="Logo NADAF"> {# Alt text pour l'image Twitter #}
    {# <meta name="twitter:site" content="@VotreCompteTwitter"> #} {# Si vous avez un compte Twitter #}
</head>
<body>
    <header>
        <div class="top-bar">
            <div class="container">
                <div class="top-bar__location">
                    <button
                      type="button"
                      class="top-bar__location-trigger"
                      aria-expanded="false"
                      aria-controls="location-map-popup"
                      id="location-map-trigger">
                      <span aria-hidden="true">📍</span>
                      <span>{{ contact.locationLabel }}</span>
                    </button>
                    <div
                      id="location-map-popup"
                      class="top-bar__map-popup"
                      role="region"
                      aria-label="Localisation de NADAF">
                      <p class="top-bar__map-caption">{{ contact.companyName }} — {{ contact.addressShort }}</p>
                      <div class="top-bar__map-frame" data-map-src="{{ contact.maps.googleEmbedUrl }}">
                        <iframe
                          title="Carte Google Maps - NADAF Ecorecup"
                          loading="lazy"
                          referrerpolicy="no-referrer-when-downgrade"
                          tabindex="-1"></iframe>
                      </div>
                    </div>
                </div>
                <div class="top-bar__contact">
                    <span>📧 <a href="mailto:{{ contact.email }}">{{ contact.email }}</a></span>
                    <span>📞 <a href="{{ contact.phoneLink }}">{{ contact.phoneDisplay }}</a></span>
                </div>
            </div>
        </div>
        <nav class="main-nav">
            <div class="container">
                <div class="main-nav__logo">
                    <a href="/fr/"> {# Lien vers l'accueil français #}
                        <img src="/static/images/logo_nadaf.jpg" alt="Logo NADAF" class="logo-image">
                    </a>
                </div>
                <ul class="main-nav__links">
                    <li>
                        <a href="/fr/" class="{% if page.url | navActive('/fr/') %}active{% endif %}"{% if page.url | navActive('/fr/') %} aria-current="page"{% endif %}>Accueil</a>
                    </li>
                    <li>
                        <a href="/fr/services/" class="{% if page.url | navActive('/fr/services/') %}active{% endif %}"{% if page.url | navActive('/fr/services/') %} aria-current="page"{% endif %}>Services</a>
                    </li>
                    <li>
                        <a href="/fr/produits/" class="{% if page.url | navActive('/fr/produits/') %}active{% endif %}"{% if page.url | navActive('/fr/produits/') %} aria-current="page"{% endif %}>Produits</a>
                    </li>
                    <li>
                        <a href="/fr/contact/" class="{% if page.url | navActive('/fr/contact/') %}active{% endif %}"{% if page.url | navActive('/fr/contact/') %} aria-current="page"{% endif %}>Contact</a>
                    </li>
                </ul>
                <button class="mobile-menu-toggle" aria-label="Ouvrir le menu" aria-expanded="false">
                    <span class="mobile-menu-toggle__bar"></span>
                    <span class="mobile-menu-toggle__bar"></span>
                    <span class="mobile-menu-toggle__bar"></span>
                </button>
            </div>
        </nav>
    </header>

    <main>
        {{ content | safe }}
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-contact">
                    <h4>Contactez-nous</h4>
                    <p>📧 <a href="mailto:{{ contact.email }}">{{ contact.email }}</a></p>
                    <p>📞 <a href="{{ contact.phoneLink }}">{{ contact.phoneDisplay }}</a></p>
                    {# Add Address later if needed #}
                </div>
                <div class="footer-links">
                    <h4>Liens Rapides</h4>
                    <ul>
                        <li><a href="/fr/">Accueil</a></li>
                        <li><a href="/fr/services/">Services</a></li>
                        <li><a href="/fr/produits/">Produits</a></li>
                        <li><a href="/fr/contact/">Contact</a></li>
                        <li><a href="/fr/mentions-legales/">Mentions Légales</a></li>
                        <li><a href="/fr/mentions-legales/#politique-de-confidentialite">Politique de Confidentialité</a></li>
                    </ul>
                </div>
                <div class="footer-social">
                    <h4>Suivez-nous</h4>
                     {# Add actual links later #}
                    <a href="https://www.facebook.com/profile.php?id=61574886006544" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                        <img src="/static/images/icons/facebook.svg" alt="Facebook" class="social-icon">
                    </a>
                    <a href="https://www.linkedin.com/in/abdelhamid-dafri-ab2619353/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                        <img src="/static/images/icons/linkedin.svg" alt="LinkedIn" class="social-icon">
                    </a>
                </div>
            </div>
            <div class="footer-copyright">
                <p>&copy; {% year %} {{ contact.companyName }}. Tous droits réservés.</p>
            </div>
        </div>
    </footer>

    {# Placeholder for JavaScript files if needed later #}
    <script src="/static/js/main.js"></script>
</body>
</html> 