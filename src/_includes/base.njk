<!DOCTYPE html>
<html lang="{{ lang }}" dir="{{ dir }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title | default('NADAF') }}</title>
    <meta name="description" content="{{ description | default('NADAF - Spécialiste du recyclage papier et carton en Algérie.') }}">
    <link rel="canonical" href="{{ metadata.baseUrl }}{{ page.url }}">
    {% for language in languages.list %}
    <link rel="alternate" hreflang="{{ language.code }}" href="{{ metadata.baseUrl }}{{ page.url | alternateUrl(language.code) }}">
    {% endfor %}
    <link rel="alternate" hreflang="x-default" href="{{ metadata.baseUrl }}/fr/">
    {% if robots %}<meta name="robots" content="{{ robots }}">{% endif %}
    <link rel="stylesheet" href="/static/css/main.css">
    <link rel="icon" href="/static/images/icons/logo_nadaf.png" type="image/x-icon">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700&family=Montserrat:wght@400;700&family=Noto+Sans+Arabic:wght@400;700&display=swap" rel="stylesheet">

    {% set currentLang = languages | langMeta(lang) %}
    <meta property="og:title" content="{{ title | default('NADAF - Recyclage Papier & Carton') }}">
    <meta property="og:description" content="{{ description | default('Collecte et valorisation de déchets papier et carton pour les entreprises en Algérie.') }}">
    <meta property="og:image" content="{{ metadata.baseUrl }}/static/images/logo_nadaf.jpg">
    <meta property="og:image:alt" content="Logo NADAF">
    <meta property="og:url" content="{{ metadata.baseUrl }}{{ page.url }}">
    <meta property="og:type" content="website">
    <meta property="og:locale" content="{{ currentLang.locale }}">
    {% for language in languages.list %}
      {% if language.code != lang %}
    <meta property="og:locale:alternate" content="{{ language.locale }}">
      {% endif %}
    {% endfor %}
    <meta property="og:site_name" content="NADAF">

    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="{{ title | default('NADAF - Recyclage Papier & Carton') }}">
    <meta name="twitter:description" content="{{ description | default('Collecte et valorisation de déchets papier et carton pour les entreprises en Algérie.') }}">
    <meta name="twitter:image" content="{{ metadata.baseUrl }}/static/images/logo_nadaf.jpg">
    <meta name="twitter:image:alt" content="Logo NADAF">

    {% if metadata.umami and metadata.umami.websiteId %}
    <script defer src="{{ metadata.umami.scriptUrl }}" data-website-id="{{ metadata.umami.websiteId }}"></script>
    {% endif %}
</head>
<body{% if '/contact/' not in page.url %} class="has-mobile-cta"{% endif %}>
    {% set t = ui[lang] %}
    <a class="skip-link" href="#main-content">{{ t.a11y.skipToContent }}</a>
    <header>
        <div class="top-bar">
            <div class="container">
                <div class="top-bar__location">
                    <button
                      type="button"
                      class="top-bar__location-trigger"
                      aria-expanded="false"
                      aria-controls="location-map-popup"
                      id="location-map-trigger">
                      <img src="/static/images/icons/icon-pin.svg" alt="" class="top-bar__icon" width="16" height="16" aria-hidden="true">
                      <span>{{ t.topBar.locationLabel }}</span>
                    </button>
                    <div
                      id="location-map-popup"
                      class="top-bar__map-popup"
                      role="region"
                      aria-label="{{ t.topBar.mapAria }}">
                      <p class="top-bar__map-caption">{{ contact.companyName }} — {{ contact.addressShort }}</p>
                      <div class="top-bar__map-frame" data-map-src="{{ contact.maps.googleEmbedUrl }}">
                        <iframe
                          title="{{ t.topBar.mapTitle }}"
                          loading="lazy"
                          referrerpolicy="no-referrer-when-downgrade"
                          tabindex="-1"></iframe>
                      </div>
                    </div>
                </div>
                <div class="top-bar__contact">
                    <a class="top-bar__contact-link" href="mailto:{{ contact.email }}">
                      <img src="/static/images/icons/icon-mail.svg" alt="" class="top-bar__icon" width="16" height="16" aria-hidden="true">
                      <span>{{ contact.email }}</span>
                    </a>
                    <a class="top-bar__contact-link" href="{{ contact.phoneLink }}">
                      <img src="/static/images/icons/icon-phone.svg" alt="" class="top-bar__icon" width="16" height="16" aria-hidden="true">
                      <span>{{ contact.phoneDisplay }}</span>
                    </a>
                </div>
            </div>
        </div>
        <nav class="main-nav">
            <div class="container">
                <div class="main-nav__logo">
                    <a href="{{ '/' | localeUrl(lang) }}">
                        <picture>
                          <source srcset="/static/images/logo_nadaf.webp" type="image/webp">
                          <img src="/static/images/logo_nadaf.jpg" alt="Logo NADAF" class="logo-image" width="451" height="497" decoding="async">
                        </picture>
                    </a>
                </div>
                <ul class="main-nav__links">
                    <li>
                        <a href="{{ '/' | localeUrl(lang) }}" class="{% if page.url | navActive('/' + lang + '/') %}active{% endif %}"{% if page.url | navActive('/' + lang + '/') %} aria-current="page"{% endif %}>{{ t.nav.home }}</a>
                    </li>
                    <li>
                        <a href="{{ '/services/' | localeUrl(lang) }}" class="{% if page.url | navActive('/' + lang + '/services/') %}active{% endif %}"{% if page.url | navActive('/' + lang + '/services/') %} aria-current="page"{% endif %}>{{ t.nav.services }}</a>
                    </li>
                    <li>
                        <a href="{{ '/produits/' | localeUrl(lang) }}" class="{% if page.url | navActive('/' + lang + '/produits/') %}active{% endif %}"{% if page.url | navActive('/' + lang + '/produits/') %} aria-current="page"{% endif %}>{{ t.nav.products }}</a>
                    </li>
                    <li>
                        <a href="{{ '/contact/' | localeUrl(lang) }}" class="{% if page.url | navActive('/' + lang + '/contact/') %}active{% endif %}"{% if page.url | navActive('/' + lang + '/contact/') %} aria-current="page"{% endif %}>{{ t.nav.contact }}</a>
                    </li>
                </ul>
                <div class="lang-switcher" role="navigation" aria-label="{{ t.langSwitcher.label }}">
                    {% for language in languages.list %}
                    <a
                      href="{{ page.url | alternateUrl(language.code) }}"
                      hreflang="{{ language.code }}"
                      lang="{{ language.code }}"
                      class="lang-switcher__link{% if language.code == lang %} is-active{% endif %}"
                      {% if language.code == lang %}aria-current="true"{% endif %}
                      title="{{ language.name }}">
                      <img
                        src="{{ language.flag }}"
                        alt="{{ language.name }}"
                        class="lang-switcher__flag"
                        width="28"
                        height="20"
                        decoding="async">
                      <span class="visually-hidden">{{ language.name }}</span>
                    </a>
                    {% endfor %}
                </div>
                <button
                  class="mobile-menu-toggle"
                  aria-label="{{ t.nav.openMenu }}"
                  aria-expanded="false"
                  data-label-open="{{ t.nav.openMenu }}"
                  data-label-close="{{ t.nav.closeMenu }}">
                    <span class="mobile-menu-toggle__bar"></span>
                    <span class="mobile-menu-toggle__bar"></span>
                    <span class="mobile-menu-toggle__bar"></span>
                </button>
            </div>
        </nav>
    </header>

    <main id="main-content" tabindex="-1">
        {{ content | safe }}
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-contact">
                    <h4>{{ t.footer.contactUs }}</h4>
                    <p>
                      <a href="mailto:{{ contact.email }}">
                        <img src="/static/images/icons/icon-mail.svg" alt="" class="footer-inline-icon" width="14" height="14" aria-hidden="true">
                        {{ contact.email }}
                      </a>
                    </p>
                    <p>
                      <a href="{{ contact.phoneLink }}">
                        <img src="/static/images/icons/icon-phone.svg" alt="" class="footer-inline-icon" width="14" height="14" aria-hidden="true">
                        {{ contact.phoneDisplay }}
                      </a>
                    </p>
                </div>
                <div class="footer-links">
                    <h4>{{ t.footer.quickLinks }}</h4>
                    <ul>
                        <li><a href="{{ '/' | localeUrl(lang) }}">{{ t.nav.home }}</a></li>
                        <li><a href="{{ '/services/' | localeUrl(lang) }}">{{ t.nav.services }}</a></li>
                        <li><a href="{{ '/produits/' | localeUrl(lang) }}">{{ t.nav.products }}</a></li>
                        <li><a href="{{ '/contact/' | localeUrl(lang) }}">{{ t.nav.contact }}</a></li>
                        <li><a href="{{ '/mentions-legales/' | localeUrl(lang) }}">{{ t.footer.legal }}</a></li>
                        <li><a href="{{ '/mentions-legales/' | localeUrl(lang) }}#politique-de-confidentialite">{{ t.footer.privacy }}</a></li>
                    </ul>
                </div>
                <div class="footer-social">
                    <h4>{{ t.footer.followUs }}</h4>
                    <a href="https://www.facebook.com/profile.php?id=61574886006544" target="_blank" rel="noopener noreferrer" aria-label="{{ t.social.facebook }}">
                        <img src="/static/images/icons/facebook.svg" alt="{{ t.social.facebook }}" class="social-icon">
                    </a>
                    <a href="https://www.linkedin.com/in/abdelhamid-dafri-ab2619353/" target="_blank" rel="noopener noreferrer" aria-label="{{ t.social.linkedin }}">
                        <img src="/static/images/icons/linkedin.svg" alt="{{ t.social.linkedin }}" class="social-icon">
                    </a>
                </div>
            </div>
            <div class="footer-copyright">
                <p>&copy; {% year %} {{ contact.companyName }}. {{ t.footer.rights }}</p>
            </div>
        </div>
    </footer>

    {% if '/contact/' not in page.url %}
    <div class="mobile-cta-bar" role="region" aria-label="{{ t.mobileCta.label }}">
      <a class="mobile-cta-bar__call" href="{{ contact.phoneLink }}">
        <img src="/static/images/icons/icon-phone.svg" alt="" width="16" height="16" aria-hidden="true">
        {{ t.mobileCta.call }}
      </a>
      <a class="button mobile-cta-bar__collect" href="{{ '/contact/' | localeUrl(lang) }}">{{ t.mobileCta.collect }}</a>
    </div>
    {% endif %}

    <script src="/static/js/main.js"></script>
</body>
</html>
